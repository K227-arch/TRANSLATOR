# Root .env for docker-compose production overrides
# Copy to .env and fill in your values before running:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# Public URL of the backend API (used by the browser, must be publicly reachable)
API_URL=https://api.yourdomain.com

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://yourdomain.com

# Ollama model (default: llama3.2:3b)
OLLAMA_MODEL=llama3.2:3b
