# ── Backend environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# CORS — comma-separated list of allowed frontend origins
# Production: set to your actual frontend domain(s)
# Development: http://localhost:3002
CORS_ORIGINS=http://localhost:3002

# HuggingFace configuration
# HF_TOKEN is optional - only needed for private models or higher rate limits
HF_TOKEN=

# HuggingFace username/organization for model repositories
# Models are loaded from: {HF_USERNAME}/lunyoro-{model-name}
HF_USERNAME=keithtwesigye

# HuggingFace Router chat model (replaces Ollama)
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

# History file path (absolute path recommended in production)
# Default: history.json in the backend directory
HISTORY_FILE=

# Port (used by start scripts)
PORT=8000

# GitHub token for sync_feedback.py (required for feedback sync)
# Generate at: https://github.com/settings/tokens
# Needs 'repo' scope to read feedback_pairs.json from repository
GITHUB_TOKEN=
