# ── Backend environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# CORS — comma-separated list of allowed frontend origins
# Production: set to your actual frontend domain(s)
# Development: http://localhost:3002
CORS_ORIGINS=http://localhost:3002

# Ollama LLM service URL
# Production: http://ollama:11434 (if using Docker) or your hosted Ollama URL
# Development: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Ollama model to use for chat
OLLAMA_MODEL=llama3.2:3b

# HuggingFace token (only needed for pushing models, not for inference)
HF_TOKEN=

# Transformers offline mode — set to 1 in production to prevent network calls
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
HF_HUB_OFFLINE=1

# History file path (absolute path recommended in production)
# Default: history.json in the backend directory
HISTORY_FILE=

# Port (used by start scripts)
PORT=8000
